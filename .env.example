# コピーして .env として使うか、ホストの環境変数に設定してください。

# --- 永続化（本番では必須推奨）---
# Render / Railway 等で Postgres を作成し、接続 URL を貼り付け
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# デプロイ後に一度（スキーマ反映）:
#   npm run db:push

# --- Google スプレッドシート（任意: 設定画面と二重でも可）---
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...1行JSON...}
# SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- eBay API（任意: 設定画面と二重でも可）---
# EBAY_APP_ID=
# EBAY_CERT_ID=

# --- ファイル永続化（DATABASE_URL が無いときのみ）---
# PERSIST_DATA_DIR=/path/to/dir
# PERSIST_STATE=0   # 0 または false でファイル永続化を無効（メモリのみ）
